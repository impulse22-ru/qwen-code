{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "composite": true,
    "jsx": "react-jsx"
  },
  "include": [
    "*.ts",
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts"
  ],
  "references": [
    {
      "path": "../core"
    },
    {
      "path": "../modes"
    },
    {
      "path": "../prompt-enhancer"
    }
  ]
}
